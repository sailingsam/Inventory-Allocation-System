# Copy to `.env` for local dev. Real env vars override these in containers/prod.

DEBUG=True
SECRET_KEY=dev-insecure-secret-key-change-me
ALLOWED_HOSTS=*

# PostgreSQL is required (the FCFS engine relies on real row-level + advisory locking).
DATABASE_URL=postgres://oms:oms@localhost:5432/oms

# Celery / Redis (bonus)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Allocation behaviour on shortage: True -> BACKORDERED, False -> leave PENDING for retry
ALLOCATION_BACKORDER_ON_SHORTAGE=True

# Frontend origin (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:3000
